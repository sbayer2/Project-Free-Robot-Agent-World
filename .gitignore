# --- pseudo-marble generated artifacts ---
# Synthetic datasets, renders, baked physics, checkpoints — regenerate, don't commit.
# Anchored to repo root so it does NOT match src/pseudomarble/data/ (source code).
/data/
/outputs/
/runs/
/checkpoints/
*.ckpt
*.safetensors
*.npz
*.ply          # gaussian splats / point clouds
*.blend1       # blender autosave
*.obj          # decomposed collision hulls (regenerated)
!docs/**/*.obj # ...unless a doc explicitly ships one as an example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# --- Tooling / caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Editors / OS ---
.vscode/
.idea/
.DS_Store
*.swp

# MuJoCo instability warning logs (dropped in cwd by mj_step)
MUJOCO_LOG.TXT
